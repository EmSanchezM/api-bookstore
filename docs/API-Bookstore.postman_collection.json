								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Gabriel José\",\n  \"biography\": \"Gabriel José de la Concordia García Márquez fue un escritor, guionista, editor y periodista colombiano. Premio Nobel de Literatura en 1982.\",\n  \"awards\": [\"Premio Nobel de Literatura 1982\", \"Premio Rómulo Gallegos 1972\", \"Legión de Honor de Francia\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/authors/{{authorId}}",
							"host": ["{{baseUrl}}"],
							"path": ["authors", "{{authorId}}"]
						},
