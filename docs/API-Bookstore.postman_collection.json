								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response && response.id) {",
									"        pm.collectionVariables.set('userId', response.id);",
									"    }",
									"    pm.test('User registered successfully', function () {",
									"        pm.response.to.have.status(201);",
									"    });",
									"}"
								],
