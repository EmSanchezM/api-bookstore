	"item": [
		{
			"name": "Authors",
			"item": [
				{
					"name": "Create Author",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response && response.id) {",
									"        pm.collectionVariables.set('authorId', response.id);",
									"    }",
									"    pm.test('Author created successfully', function () {",
									"        pm.response.to.have.status(201);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Gabriel\",\n  \"lastName\": \"García Márquez\",\n  \"nationality\": \"Colombiana\",\n  \"biography\": \"Gabriel José de la Concordia García Márquez fue un escritor y periodista colombiano, reconocido principalmente por sus novelas y cuentos, también escribió no ficción, discursos y reportajes.\",\n  \"awards\": [\"Premio Nobel de Literatura 1982\", \"Premio Rómulo Gallegos 1972\"],\n  \"genres\": [\"Realismo mágico\", \"Ficción literaria\"],\n  \"notableWorks\": [\"Cien años de soledad\", \"El amor en los tiempos del cólera\"],\n  \"socialLinks\": {\n    \"facebook\": \"https://facebook.com/gabrielgarciamarquez\",\n    \"twitter\": \"https://twitter.com/garciamarquez\",\n    \"instagram\": \"https://instagram.com/garciamarquez\"\n  },\n  \"website\": \"https://www.garciamarquez.com\",\n  \"birthDate\": \"1927-03-06\",\n  \"dateOfDeath\": \"2014-04-17\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/authors",
							"host": ["{{baseUrl}}"],
							"path": ["authors"]
						},
						"description": "Crea un nuevo autor. Todos los campos son requeridos excepto dateOfDeath."
					}
				},
				{
					"name": "Get All Authors",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/authors",
							"host": ["{{baseUrl}}"],
							"path": ["authors"]
						},
						"description": "Obtiene la lista de todos los autores."
					}
				},
				{
					"name": "Get Author by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/authors/{{authorId}}",
							"host": ["{{baseUrl}}"],
							"path": ["authors", "{{authorId}}"]
						},
						"description": "Obtiene un autor por su ID."
					}
				},
				{
					"name": "Get Authors with Filters",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/authors/filters?name=Gabriel&nationality=Colombiana&isActive=true&skip=0&limit=10&orderBy=firstName&sortBy=asc",
							"host": ["{{baseUrl}}"],
							"path": ["authors", "filters"],
							"query": [
								{
									"key": "name",
									"value": "Gabriel",
									"description": "Filtrar por nombre"
								},
								{
									"key": "nationality",
									"value": "Colombiana",
									"description": "Filtrar por nacionalidad"
								},
								{
									"key": "isActive",
									"value": "true",
									"description": "Filtrar por estado activo/inactivo"
								},
								{
									"key": "skip",
									"value": "0",
									"description": "Registros a saltar (paginación)"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Límite de registros"
								},
								{
									"key": "orderBy",
									"value": "firstName",
